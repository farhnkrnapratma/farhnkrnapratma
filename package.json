{
  "name": "farhnkrnapratma",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun ./src/build.ts",
    "clean": "bun -e \"import {rmSync} from 'fs'; rmSync('./build', {recursive:true, force:true})\"",
    "serve": "bun --hot ./src/server.ts",
    "lint": "bunx --bun @biomejs/biome lint --write",
    "format": "bunx --bun @biomejs/biome format --write"
  }
}
